# shakha.uz — Nginx static-export config example
#
# Deploy: copy the `out/` directory produced by `npm run build` to the server root:
#   rsync -av --delete out/ user@server:/var/www/shakha.uz/out/
#
# The build uses `trailingSlash: true`, so every page is a directory with an
# index.html inside (e.g. /en/projects/ → /en/projects/index.html).

server {
    listen 80;
    server_name shakha.uz www.shakha.uz;

    # Redirect HTTP → HTTPS (enable once TLS is configured)
    # return 301 https://$host$request_uri;

    root /var/www/shakha.uz/out;
    index index.html;

    # ------------------------------------------------------------------
    # Security headers — applied to all responses in this server block.
    #
    # CSP rationale:
    #   default-src 'self'          — baseline deny-by-default
    #   img-src 'self' data:        — allow inline data: URIs (Next.js blurred
    #                                  placeholders) and same-origin images
    #   style-src 'self' 'unsafe-inline'  — Next.js static export injects small
    #                                        inline <style> blocks; required
    #   script-src 'self' 'unsafe-inline' — Next.js static export injects an
    #                                        inline bootstrap chunk; required.
    #                                        Can be replaced with a nonce-based
    #                                        policy if you move off static export
    #                                        and use Next.js middleware + nonces.
    #   font-src 'self'             — fonts served from same origin (Google Fonts
    #                                  are subset and self-hosted via next/font)
    #   connect-src 'self'          — no external XHR/fetch in this static site
    #   frame-ancestors 'self'      — replaces X-Frame-Options where supported
    #   object-src 'none'           — disable Flash / plugins entirely
    #   base-uri 'self'             — prevent <base> injection attacks
    #   form-action 'self'          — no external form submissions
    #
    # NOTE: Strict-Transport-Security is only meaningful over HTTPS.
    # Move it (or uncomment) into the https server block below in production.
    # ------------------------------------------------------------------
    add_header X-Content-Type-Options        "nosniff"                                                always;
    add_header X-Frame-Options               "SAMEORIGIN"                                             always;
    add_header Referrer-Policy               "strict-origin-when-cross-origin"                        always;
    add_header Permissions-Policy            "camera=(), microphone=(), geolocation=()"               always;
    add_header Content-Security-Policy       "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none';" always;

    # ------------------------------------------------------------------
    # OG images: Next.js emits these as extension-less PNG files at paths
    # like /en/opengraph-image, /en/projects/opengraph-image, etc.
    # Without an explicit type Nginx sends application/octet-stream, which
    # breaks social-media crawlers (Twitter, Open Graph). Force image/png.
    # Must appear BEFORE the generic location / block.
    # ------------------------------------------------------------------
    location ~ /opengraph-image$ {
        default_type image/png;
        add_header Content-Type image/png;
        try_files $uri =404;
    }

    # Redirect bare root → /en/ (the default locale)
    location = / {
        return 302 /en/;
    }

    # sitemap and robots are plain files in out/
    location = /sitemap.xml {
        try_files $uri =404;
        add_header Content-Type application/xml;
    }

    location = /robots.txt {
        try_files $uri =404;
        add_header Content-Type text/plain;
    }

    # Long cache for content-hashed Next.js assets
    location /_next/static/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # General static-export serving
    # trailingSlash: true → try directory index first, then .html, then 404
    location / {
        try_files $uri $uri/ $uri.html =404;
    }

    # Custom 404 page (generated at build time)
    error_page 404 /en/404.html;
}

# ------------------------------------------------------------------
